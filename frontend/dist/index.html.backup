        <!-- cta 2-->
        <section class="box-cta-2 background-body overflow-hidden">
            <div class="bg-shape top-50 start-50 translate-middle"></div>
            <div class="container position-relative z-1">
                <div class="row ">
                    <div class="col-lg-5 pe-lg-5 ">
                        <h3 class="text-white wow fadeInDown">Want to Calculate Your Car Payment?</h3>
                        <p class="text-lg-medium text-white wow fadeInUp">Match with up to 4 lenders to get the lowest rate available with no markups, no fees, and no obligations.</p>
                    </div>
                    <div class="col-lg-6 offset-lg-1">
                        <div class="mb-30 background-card p-md-5 p-4 rounded-3 mt-lg-0 mt-30 wow fadeIn">
                            <h5 class="neutral-1000 mb-2">Car Loan Calculator</h5>
                            <p class="text-sm-medium neutral-500 mb-25">Estimate your monthly auto loan payments with this calculator.</p>
                            <div class="form-contact">
                                <div class="row">
                                    <div class="col-lg-6">
                                        <div class="form-group">
                                            <label class="text-sm-medium neutral-1000">Price of vehicle</label>
                                            <input class="form-control" type="text" placeholder="$20,000" />
                                        </div>
                                    </div>
                                    <div class="col-lg-6">
                                        <div class="form-group">
                                            <label class="text-sm-medium neutral-1000">Interest rate</label>
                                            <input class="form-control" type="text" placeholder="5%" />
                                        </div>
                                    </div>
                                    <div class="col-lg-6">
                                        <div class="form-group">
                                            <label class="text-sm-medium neutral-1000">Terms</label>
                                            <input class="form-control" type="text" placeholder="12 months" />
                                        </div>
                                    </div>
                                    <div class="col-lg-6">
                                        <div class="form-group">
                                            <label class="text-sm-medium neutral-1000">Down payment</label>
                                            <input class="form-control" type="text" placeholder="$12,000" />
                                        </div>
                                    </div>
                                    <div class="row py-4">
                                        <div class="col-md-5 col-8 d-flex flex-column gap-1">
                                            <p class="text-sm-bold neutral-1000">Down payment ammout</p>
