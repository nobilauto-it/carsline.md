        /* Ęđŕńčâűé ńęđîëëáŕđ äë˙ ýëĺěĺíňîâ ń overflow */
        .scrollable-content {
            scrollbar-width: thin;
            scrollbar-color: #1a237e #f8f9fa;
        }
        
        .scrollable-content::-webkit-scrollbar {
            width: 8px;
