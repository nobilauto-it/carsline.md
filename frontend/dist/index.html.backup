        /* Ńňčëčçŕöč˙ äë˙ áîęîâîé ďŕíĺëč ôčëüňđîâ */
        .sidebar-left {
            scrollbar-width: thin;
            scrollbar-color: #1a237e #ffffff;
        }
        
        .sidebar-left::-webkit-scrollbar {
            width: 6px;
        }
        
        .sidebar-left::-webkit-scrollbar-track {
            background: #ffffff;
            border-radius: 6px;
