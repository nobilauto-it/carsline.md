    <!-- Custom Scrollbar Styles -->
    <style>
        /* Ęđŕńčâűé ńęđîëëáŕđ äë˙ Webkit áđŕóçĺđîâ (Chrome, Safari, Edge) */
        ::-webkit-scrollbar {
            width: 12px;
            height: 12px;
        }
        
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #1a237e 0%, #3f51b5 50%, #5c6bc0 100%);
