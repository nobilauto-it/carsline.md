        ::-webkit-scrollbar-corner {
            background: #f1f1f1;
        }
        
        /* Äë˙ Firefox */
        html {
            scrollbar-width: thin;
            scrollbar-color: #1a237e #f1f1f1;
        }
        
        /* Ďëŕâíŕ˙ ďđîęđóňęŕ */
        html {
            scroll-behavior: smooth;
        }
        
        /* Ńňčëčçŕöč˙ ńęđîëëáŕđŕ äë˙ ňĺěíîé ňĺěű */
        @media (prefers-color-scheme: dark) {
            ::-webkit-scrollbar-track {
                background: #2a2a2a;
            }
            
            ::-webkit-scrollbar-thumb {
                background: linear-gradient(135deg, #3f51b5 0%, #5c6bc0 50%, #7986cb 100%);
                border: 2px solid #2a2a2a;
            }
            
            ::-webkit-scrollbar-thumb:hover {
                background: linear-gradient(135deg, #283593 0%, #3949ab 50%, #5c6bc0 100%);
            }
            
            ::-webkit-scrollbar-corner {
                background: #2a2a2a;
            }
            
            html {
                scrollbar-color: #3f51b5 #2a2a2a;
            }
        }
        
        /* Ŕíčěŕöč˙ ďî˙âëĺíč˙ ńęđîëëáŕđŕ */
        ::-webkit-scrollbar-thumb {
            opacity: 0.7;
        }
        
        *:hover::-webkit-scrollbar-thumb {
            opacity: 1;
        }
        
        /* Ńňčëčçŕöč˙ äë˙ ěîáčëüíűő óńňđîéńňâ */
        @media (max-width: 768px) {
            ::-webkit-scrollbar {
                width: 8px;
                height: 8px;
            }
            
            ::-webkit-scrollbar-thumb {
                border: 1px solid #f1f1f1;
            }
